# Skopiuj jako game-path.env w katalogu glownym projektu (obok patches/).

# --- Linux / SteamOS (Flatpak Steam) ---
# WOL_STREAMING="$HOME/.var/app/com.valvesoftware.Steam/data/Steam/steamapps/common/West of Loathing/West of Loathing_Data/StreamingAssets"

# --- Linux (Steam natywny) ---
# WOL_STREAMING="$HOME/.local/share/Steam/steamapps/common/West of Loathing/West of Loathing_Data/StreamingAssets"

# --- macOS (Steam) ---
# WOL_STREAMING="$HOME/Library/Application Support/Steam/steamapps/common/West of Loathing/West of Loathing_Data/StreamingAssets"

# --- Windows (odkomentuj w game-path.env bez cudzyslowow bash) ---
# WOL_STREAMING=C:\Program Files (x86)\Steam\steamapps\common\West of Loathing\West of Loathing_Data\StreamingAssets
